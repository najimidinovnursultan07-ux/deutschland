# Session signing for httpOnly auth cookies (required on Vercel)
SESSION_SECRET=your-random-secret-here

# Root admin seed password (server-side, bcrypt hashed on first auth request)
ROOT_ADMIN_PASSWORD=change-me-in-production

# Local dev fallback if ROOT_ADMIN_PASSWORD is unset
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=admin123456

# Upstash Redis — REQUIRED on Vercel (auth & progress are lost without it)
# Create free database: https://console.upstash.com
# Or in Vercel: Project → Storage → Create Database → Redis → Connect
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local Next.js (optional)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=

# Telegram — suggestion notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
