# Session signing for httpOnly auth cookies (required in production)
SESSION_SECRET=your-random-secret-here

# Root admin seed password (server-side, bcrypt hashed on first auth request)
ROOT_ADMIN_PASSWORD=change-me-in-production

# Local dev fallback if ROOT_ADMIN_PASSWORD is unset
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=admin123456

# Upstash Redis — REQUIRED on Vercel (without it user accounts are lost on cold starts)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Telegram — suggestion notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional: LAN / mobile testing (Next.js full-stack) ---
# Leave EMPTY for normal use (relative /api/* URLs — works on localhost AND phone IP).
# Set only if API runs on a DIFFERENT host/port than the UI (e.g. separate Express server):
# NEXT_PUBLIC_API_ORIGIN=http://192.168.1.10:5000
#
# Mobile on same Wi‑Fi: run `npm run dev:lan`, open http://YOUR_LAPTOP_IP:3000 on phone.
# Allow port 3000 in Windows Firewall if the page loads but API fails.
